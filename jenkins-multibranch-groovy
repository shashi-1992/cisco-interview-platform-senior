        }
        
    }
    if (!args.deploymentBranch || args.deploymentBranch == '') {
        args.deploymentBranch = Constants.DEPLOYMENT_BRANCH
    }
   
    stage('Clone Exotel_deployments repo') {
        pipelineStep.createDirectory('exotel_deployments')
        dir('exotel_deployments') {
            url = Constants.REPO_BASE_URL + '/' + args.deploymentRepo + '.git'
            print url
            branch = args.deploymentBranch
            pipelineStep.checkout(url, branch)
        }
    }

    stage('Clone last stable deployment files') {
        // canary is enabled in Jenkinsfile.
        // Now, checkout exotel_deployments with the last stable commit
        if (args.enableCanary) {
