package io.estrado.components

//Lints Dockerfile based on Hadolint/hadolint
def lintDockerfile(String DockerFilePath, String Dockerfile) {
    if (DockerFilePath?.trim()) {
        container('builder') {
            dir(DockerFilePath) {
                def lintResult = sh(script: "nerdctl run --rm -i hadolint/hadolint < ${Dockerfile}", returnStdout: true)
            }
        }
    } else {
        throw new Exception("Invalid Dockerfile Path Passed.")
    }
}

//Builds docker image
def imageBuild(String DockerfilePath, String Dockerfile, String overriddenTag) {
    dir(DockerfilePath) {
        def dockerEnv = "DOCKER_CONFIG=/root/.dockerhubsecret"
        if (overriddenTag != ""){
            def image = sh(script: "${dockerEnv} nerdctl build --no-cache -q -t ${env.ECR_REPO}:latest -f ${Dockerfile} .", returnStdout: true)
        }else{
            def image = sh(script: "${dockerEnv} nerdctl build -t ${env.ECR_REPO}:latest -f ${Dockerfile} .", returnStdout: true)
        }
    }
}

def getImageDigest(String ImageName) {
    try {
        def repoDigest = sh(script: "nerdctl inspect --format='{{index .RepoDigests 0}}' ${ImageName}", returnStdout: true).trim()
        if (repoDigest) {
            return repoDigest.split("@")[1]
        }
    } catch (Exception e) {
        println "Failed to get image digest: ${e.message}"
    }
    return ""
}

//Pushes docker image
def pushImage() {
    try {
        def result = sh(script: "nerdctl push ${env.ECR_REPO}:${env.IMAGE_TAG}", returnStdout: true)
        return result
    } catch (Exception e) {
        println "Failed to push image: ${e.message}"
        throw e
    }
}

def tagImage() {
    try {
        if (env.IMAGE_TAG.trim() == "") {
            //if env.IMAGE_TAG is empty, use default tag 1.0.0.
            def applyTag = sh(script: "nerdctl tag ${env.ECR_REPO}:latest ${env.ECR_REPO}:1.0.0", returnStdout: true)
        } else {
            def applyTag = sh(script: "nerdctl tag ${env.ECR_REPO}:latest ${env.ECR_REPO}:${env.IMAGE_TAG}", returnStdout: true)
        }
    } catch (Exception e) {
        println "Failed to tag image: ${e.message}"
        throw e
    }
}

