def commitDeploymentFilesForTheStage(def pipelineStep, Map pipelineMap, Map args, String deploymentStage) {
    stage("Commit ${deploymentStage} Files") {
        container('helm') {
            // Copy generated helm into exotel_deployments
            sh """
            rm -rf  exotel_deployments/${args.serviceName}/${deploymentStage}/
            mkdir -p exotel_deployments/${args.serviceName}
            ls ${args.configFilePath}/${deploymentStage}/*
            mv  ${args.configFilePath}/${deploymentStage}/${args.serviceName}/templates exotel_deployments/${args.serviceName}/${deploymentStage}
            ls -ltrh
            mv ${args.configFilePath}/${deploymentStage}/BUILD_INFO.txt exotel_deployments/${args.serviceName}/${deploymentStage}/
             """
            // copy latest stable file if canary is enabled
            if (args.enableCanary) {
                pipelineStep.copyLatestStableFiles(args, deploymentStage)
            }
        }
        sshagent(['cicd-exotel']) {
            dir('exotel_deployments') {
                boolean gitPushed = false
                boolean commitPresent = false
                //counter is to shortcircuit the loop. Try only 5 times to push git
                //else mark the build as failure
                int counter = 0
                while (gitPushed == false && counter < 5) {
                    if(pipelineMap.commitID != null && pipelineMap.md5OfMerge != null){
                    commitPresent = pipelineStep.gitCommit(args.deploymentBranch, "Update K8s manifests for ${args.serviceName}-${deploymentStage}-${pipelineMap.imageTag}. Service Commit: ${pipelineMap.commitID.trim()}. Configs Commit: ${args.configsCommitID.trim()}", "${args.serviceName.trim()}-${pipelineMap.imageTag.trim()}-${pipelineMap.commitID.trim()}-${args.configsCommitID.trim()}-${pipelineMap.md5OfMerge.trim()}-${args.canaryColor}-rc"
                    )
                    echo "Files are committed and waiting to get pushed: ${commitPresent} "
                    }
                    if (commitPresent) {
                        gitPushed = pipelineStep.gitPush(args.deploymentBranch)
                        counter += 1
                    } else {
                        break
                    }
                }
                if (gitPushed == false && commitPresent == true) {
                    throw new Exception('Unable to push the changes to Git. Please check your repository commits/ settings')
                }
            }
        }
    }
}

