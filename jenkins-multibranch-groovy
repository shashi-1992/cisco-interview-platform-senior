// parses gitTag and returns the color i-e version of the deployment
def getColor(String gitTag) {
    Map colorInfo = [:]
    if (gitTag == '' || gitTag == null) {
        echo 'Error while parsing gitTag to find the deployment version. gitTag is either empty or null'
        colorInfo.currentColor = 'blue'
        colorInfo.lastColor = 'green'
        return colorInfo
    }
    String color = gitTag.split('-')[5]
    //this switch case is needed because earlier tags dont have color information at the index 6
    switch (color) {
        case 'blue':
            colorInfo.currentColor = 'green'
            colorInfo.lastColor = 'blue'
            return colorInfo
        case 'green':
            colorInfo.currentColor = 'blue'
            colorInfo.lastColor = 'green'
            return colorInfo
        default:
            colorInfo.currentColor = 'blue'
            colorInfo.lastColor = 'green'
            return colorInfo
    }
}

