package com.exotel

def run(def pipelineStep, Map args) {
    def pipelineMap = [:]
    echo 'Running common pipeline steps'
        computeGitCommits(pipelineStep, pipelineMap, args)

    stage('Search git tag for last merge md5Hash') {
        sshagent(['cicd-exotel']) {
            dir('exotel_deployments') {
                pipelineMap.tag = pipelineStep.searchGitTag(pipelineMap.md5OfMerge, args.serviceName)
                if (pipelineMap.tag == '' || pipelineMap.tag == null) {
                    sh(label: 'FAILURE MESSAGE: Could not find git tag for this merge', script: 'echo This merge commit in nextrelease branch has some additional changes compared to last proposedupdates branch build for this service. Check your changes')
                    throw new Exception('I cannot run this build')
                } else {
                    echo "Git tag for md5Hash: ${pipelineMap.md5OfMerge} is ${pipelineMap.tag}"
                }
            }
        }
    }

    stage('Fetch image tag from git tag') {
        container('builder') {
            pipelineStep.sourceRegistryCredentials()
            pipelineMap.imageTag = pipelineStep.getImageVersionFromGitTag(pipelineMap.tag)
            echo "The last image tag was ${pipelineMap.imageTag} and this is computed from the git tag ${pipelineMap.tag}"
        }
    }
    stage('Reset exotel_configs to PU state') {
        //Pu might have been tested with a service commit id and config commit id
        // now checkout to the same config commit id while generating files for qa and prod
        // We will have to see if we need this
        dir(args.configFilePath) {
            String configCommitIDInPU = pipelineMap.tag.split('-')[3].trim()
            sh """
            git reset --hard ${configCommitIDInPU}
            """
            //change the config commit id. This is the same exotel_configs commit id with which pu branch was built
            args['configsCommitID'] = configCommitIDInPU
        }
    }

    getDeploymentVersion(pipelineStep, args)

    return pipelineMap
}

// use this stage to
// 1. Check if the build was triggered from a merge commit. abort the build otherwise.
// 2. Check if the there are changes between master and the branch, abort otherwise since
// there will be an image already for this code
// 3. To get merge commitId
// 4. To get md5hash fo the merge
// 5. To get merged branch name
// 6. To get last commit Id on merged branch
def computeGitCommits(def pipelineStep, Map pipelineMap, Map args) {
    stage('Compute Git Commits') {
        if (args.serviceName == 'cqa') {
            // For CQA applications, use simplified git checks
            dir('cqa-source') {
                echo "CQA: Using simplified git checks (skipping complex operations)"
                
                // Get basic commit information
                pipelineMap.mergeCommitID = pipelineStep.getCommitId()
                echo "CQA: Commit ID: ${pipelineMap.mergeCommitID}"
                
                // Use simplified branch detection
                try {
                    pipelineMap.mergedBranch = pipelineStep.getMergedBranch(pipelineMap.mergeCommitID)
                    echo "CQA: Branch: ${pipelineMap.mergedBranch}"
                } catch (Exception e) {
                    echo "CQA: Error getting branch, using fallback"
                    pipelineMap.mergedBranch = "cqa-branch"
                }
                
                // Commit ID must lead so searchGitTag's substring(0,7) gets all 7 hex chars
                pipelineMap.md5OfMerge = "${pipelineMap.mergeCommitID.substring(0, 7)}-cqa-${System.currentTimeMillis()}"
                echo "CQA: Generated MD5: ${pipelineMap.md5OfMerge}"
                
                // Use commit ID directly
                pipelineMap.commitID = pipelineMap.mergeCommitID.substring(0, 7)
                echo "CQA: Using commit ID: ${pipelineMap.commitID}"
                
                echo "CQA: Simplified git checks completed successfully"
            }
        } else {
            // For other services, use current directory
            pipelineMap.mergeCommitID = pipelineStep.getCommitId()
            pipelineMap.mergedBranch = pipelineStep.getMergedBranch(pipelineMap.mergeCommitID)
            if (pipelineStep.checkMergeCommit(pipelineMap.mergeCommitID) == false) {
                throw new Exception('The pipeline has not been triggered by a Merge commit. Aborting build ')
            }
            pipelineMap.md5OfMerge = pipelineStep.generateMd5HashOfCommitDiff(pipelineMap.mergeCommitID)
            pipelineMap.commitID = pipelineStep.getFirstSubcommitOfaMerge(pipelineMap.mergeCommitID)
        }
    }
}

// This stage is the precheck stage that evaluate some rules to decide the docker image build
// common check is to find whether the commitID has a corresponding docker image. otherwise get the
// last image tag
def imageBuildPreChecks(def pipelineStep, Map pipelineMap, Map args) {
    stage('Docker Image Build - Prechecks') {
        pipelineMap.shouldBuildDockerImage = false
        String tag
        sshagent(['cicd-exotel']) {
            dir('exotel_deployments') {
                // tag - top 1 tag where the tag name contains the serviceName and the md5Hash
                tag = pipelineStep.searchGitTag(pipelineMap.md5OfMerge, args.serviceName)
                if (tag == '' || tag == null) {
                    echo "There are no tags present for this diff's md5Hash ${pipelineMap.md5OfMerge} and the keyword ${args.serviceName}"
                    pipelineMap.shouldBuildDockerImage = true
                } else {
                    pipelineMap.imageTag = pipelineStep.getImageVersionFromGitTag(tag)
                    echo "Existing Image version for md5Hash: ${pipelineMap.md5OfMerge} is ${pipelineMap.imageTag} and this is computed from the git tag"
                }
            }
        }

        if (pipelineMap.shouldBuildDockerImage) {
            // Since the tag is not present for this md5Hash, now an new docker image has to built for this md5Hash
            // to tag the docker image, use the last docker tag and increment it
            container('builder') {
                pipelineStep.sourceRegistryCredentials()
                String lastDockerTag = pipelineStep.getLastImageVersionFromECR(args)
                echo "Last image tag found from ECR is : ${lastDockerTag}"
                pipelineMap.imageTag = lastDockerTag
            }
        }
    }
}

