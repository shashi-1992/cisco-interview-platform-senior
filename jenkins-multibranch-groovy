//takes a merge commit id as input and writes all subcommit
String writeAllSubCommits(String commit) {
    //check if it is a merge commit
    String countOfCommits = sh(returnStdout: true, script: "git log --pretty=format:'%h' ${commit}^..${commit} | wc -l")
    if (countOfCommits != "1") {
        sh(returnStdout: true, script: "git log  --pretty=format:'%h' ${commit}^..${commit} | sed -n '2,\$p' > commits.txt")
    } else {
        echo "Warning: This is not a merge commit"
        sh(returnStdout: true, script: "git log  --pretty=format:'%h' ${commit}^..${commit}   > commits.txt")
    }
    echo "Listing all subcommits of this commit ${commit} and it's md5sum"
    sh """
        cat commits.txt
        md5sum commits.txt
        """
    String md5Hash = sh(returnStdout: true, script: "md5sum commits.txt | awk '{print \$1}'")
    return md5Hash

}
