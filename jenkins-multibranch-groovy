// takes a semver tag and increments the patch version
String incrementSemVerPatch(String semVerTag) {
    if (checkSemanticVersionedTag(semVerTag)) {
        //split it by "."
        def splittedTags = semVerTag.tokenize(".")
        //increment the patch version
        def patchVersion = splittedTags[2].toInteger();
        // increment the patch version by 1
        patchVersion += 1
        splittedTags[2] = patchVersion.toString()
        String combinedTag = splittedTags.join(".");
        return combinedTag
    }
}

// takes a semver tag and increments the major version
String incrementSemVerMajor(String semVerTag) {
    if (checkSemanticVersionedTag(semVerTag)) {
        //split it by "."
        def splittedTags = semVerTag.tokenize(".")
        //increment the patch version
        def majorVersion = splittedTags[0].toInteger();
        // increment the patch version by 1
        majorVersion += 1
        splittedTags[0] = majorVersion.toString()
        String combinedTag = splittedTags.join(".");
        return combinedTag
    }
}

// takes a semver tag and increments the minor version
String incrementSemVerMinor(String semVerTag) {
    if (checkSemanticVersionedTag(semVerTag)) {
        //split it by "."
        def splittedTags = semVerTag.tokenize(".")
        //increment the patch version
        def minorVersion = splittedTags[1].toInteger();
        // increment the patch version by 1
        minorVersion += 1
        splittedTags[1] = minorVersion.toString()
        String combinedTag = splittedTags.join(".");
        return combinedTag
    }
}
//validates semver tag
boolean checkSemanticVersionedTag(String semVerTag) {
    if (!semVerTag.contains(".")) {
        echo "${semVerTag} is not a valid semantic versioned tag"
        return false
    }
    return true
}

