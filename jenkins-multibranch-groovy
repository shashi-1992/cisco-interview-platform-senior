        git tag --delete ${tag}
        git push --delete ${tag}
    """
    } catch (Exception e) {
        echo "Unable to delete old git tag ${tag}: ${e}"
    }
}

// commits the recent changes to git and returns true if a commit is done
boolean gitCommit(String branch, String message, String tag) {
    deleteGitTag(tag)
    sh """

     #!/usr/bin/env bash
     set +x 
     export GIT_SSH_COMMAND="ssh -oStrictHostKeyChecking=no"
     git pull origin ${branch}

    """
    String areFilesChanged = sh(returnStdout: true, script: "git status --porcelain | wc -l")
    echo "Files changed for commit ${areFilesChanged}"
    if (areFilesChanged?.trim() != "0") {
        sh """
            git add .
            git commit -m  "${message}"
        """

        if (tag != null && tag != "") {
            sh """
                git tag "${tag}"
            """
        }
        return true
    }
    return false
}

