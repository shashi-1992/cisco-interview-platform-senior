package io.estrado.pipelines

import io.estrado.artifact.Artifactory
import io.estrado.components.Common
import io.estrado.components.Docker
import io.estrado.components.Helm


def generateHelm(Map args, Map env) {

    Artifactory ecr = new Artifactory()
    Common common = new Common()
    Docker docker = new Docker()
    Helm helm = new Helm()

    def label = common.workerLabel("${args.serviceName}-helm")

    podTemplate(label: label, namespace: 'infra', serviceAccount: 'jenkins', containers: [
            containerTemplate(name: 'builder', 
                        image: 'exotelorg/nerdctl-awscli:v1', 
                        command: '/bin/sh -c', 
                        args: 'buildkitd --rootless & sleep 2 && cat', 
                        ttyEnabled: true, 
                        privileged: true,
                        volumeMounts: [mountPath: '/root/.dockerhubsecret', name: 'dockerhub-creds']),
            containerTemplate(name: 'helm', image: 'exotelorg/k8s-helm', command: 'cat', ttyEnabled: true)
    ], imagePullSecrets: ['exotelorg-dockerhub-secret'], volumes: [
            hostPathVolume(mountPath: '/run/containerd', hostPath: '/run/containerd'),
            hostPathVolume(mountPath: '/var/lib/containerd', hostPath: '/var/lib/containerd'),
            hostPathVolume(mountPath: '/var/lib/nerdctl', hostPath: '/var/lib/nerdctl'),
            hostPathVolume(mountPath: '/opt/cni/bin', hostPath: '/opt/cni/bin'),
            hostPathVolume(mountPath: '/etc/cni/net.d', hostPath: '/etc/cni/net.d'),
            secretVolume(secretName: 'exotelorg-dockerhub-secret', mountPath: '/root/.dockerhubsecret', name: 'dockerhub-creds')
    ]) {
        node(label) {
            stage('Source code checkouts') {
                helm.helmCheckout()
            }
            println "Athavan ${commonVars.GIT_BRANCH}"
            println  env
            stage('Fetch Latest Tag'){
                container('builder'){
                    env.NEW_IMAGE_TAG  = ecr.getLatestTagForHelm()
                }
            }
            if (env.GIT_BRANCH == "pu") {

                stage('Helm Generation for Integration'){
                    container("helm"){
                        dir(args.configFilePath){
                            sh """
                            ls *
                            cp -rf * k8s/
                            cd k8s/
                            helm template --name ${args.serviceName} -f values/values.${integrationStage}.yaml \
                                --set=service_image.tag=${env.NEW_IMAGE_TAG} \
                                --set=configs.commit_id=${env.CONFIG_COMMIT_SHA} \
                                --set=service_image.commit_id=${env.GIT_COMMIT_ID} > ${args.serviceName}-${integrationStage}.yaml
                            
                            """
                        }
                    }
                }
            }
        }
    }
}

