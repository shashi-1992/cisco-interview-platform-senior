def buildJars(Map args) {
    stage('Build Jar files') {
        container('jdk') {
            // Build Maven command dynamically
            def mavenCmd = "mvn ${args.mavenGoals ?: 'clean package'}"
            
            // Add skip tests if specified
            if (args.skipTests == 'true') {
                mavenCmd += " -DskipTests"
            }
            
            // Add profiles if specified
            if (args.mavenProfiles) {
