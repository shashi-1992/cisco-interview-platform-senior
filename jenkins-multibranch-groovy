def increamentImageVersion(def pipelineStep, Map pipelineMap) {
    // increment from the lastDockerTag and assign it to the imageTag
    // Decide based on the constant "AMENDABLE_SEMVERSION" to increment which version
    switch (Constants.AMENDABLE_SEMVERSION) {
            case 'minor':
            pipelineMap.imageTag = pipelineStep.incrementSemVerMinor(pipelineMap.imageTag)
            break
            case 'major':
            pipelineMap.imageTag = pipelineStep.incrementSemVerMajor(pipelineMap.imageTag)
            break
            default:
                // by default increment the Patch version
                pipelineMap.imageTag = pipelineStep.incrementSemVerPatch(pipelineMap.imageTag)
    }
}

// Determine CQA branch based on pipeline branch (same logic as other services)
    def determineCQABranch(Map args) {
        // Get the pipeline branch from Jenkins environment (same as other services)
        echo "Raw env.GIT_BRANCH: ${env.GIT_BRANCH}"
        echo "Raw env.BRANCH_NAME: ${env.BRANCH_NAME}"
        echo "Raw env.CHANGE_BRANCH: ${env.CHANGE_BRANCH}"
        // Use BRANCH_NAME if GIT_BRANCH is null (common in multibranch pipelines)
        def pipelineBranch = env.GIT_BRANCH?.replace('origin/', '')?.trim() ?: env.BRANCH_NAME
        echo "Processed pipeline branch: ${pipelineBranch}"
    
    // Map pipeline branches to CQA branches
    if (pipelineBranch == 'pu' || pipelineBranch == 'proposedupdates' || pipelineBranch == 'cqa_pu') {
        echo "Mapped pipeline branch '${pipelineBranch}' to CQA branch 'pu'"
        return 'pu'  // ← Integration uses pu branch
    } else if (pipelineBranch == 'next' || pipelineBranch == 'nextrelease' || pipelineBranch == 'cqa_next') {
        echo "Mapped pipeline branch '${pipelineBranch}' to CQA branch 'next' (now also production)"
        return 'next'  // ← QA and Production use next branch
    } else if (pipelineBranch == 'master' || pipelineBranch == 'cqa_master') {
        echo "Mapped pipeline branch '${pipelineBranch}' to CQA branch 'master'"
        return 'master'  // ← Production uses master branch
    } else {
        // Fallback to parameter or default
        echo "Using fallback branch: ${args.cqaBranch ?: 'pu'} for pipeline branch: ${pipelineBranch}"
        return args.cqaBranch ?: 'pu'
    }
}

// clones Service repo, exotel_code and exotel_configs repo
def cloneCodeRepos(def pipelineStep, Map pipelineMap, Map args) {
    // Set exotelConfigBranch dynamically based on pipeline branch (override environment variable)
    def currentPipelineBranch = env.GIT_BRANCH?.replace('origin/', '')?.trim() ?: env.BRANCH_NAME
    def originalExotelConfigBranch = args.exotelConfigBranch
    if (currentPipelineBranch == 'pu' || currentPipelineBranch == 'proposedupdates' || currentPipelineBranch == 'cqa_pu') {
        args.exotelConfigBranch = 'pu'
    } else if (currentPipelineBranch == 'next' || currentPipelineBranch == 'nextrelease' || currentPipelineBranch == 'cqa_next') {
        args.exotelConfigBranch = 'next'
    } else if (currentPipelineBranch == 'master' || currentPipelineBranch == 'cqa_master') {
        args.exotelConfigBranch = 'master'
    } else {
        args.exotelConfigBranch = 'next'  // Default fallback
    }
    echo "Overriding exotelConfigBranch from '${originalExotelConfigBranch}' to '${args.exotelConfigBranch}' based on pipeline branch: ${currentPipelineBranch}"

    // Clone CQA from vegaops with dynamic branch detection
