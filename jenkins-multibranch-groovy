//Computes and returns the latest Tag for the ECR image repository
def getLatestImageTag(){
    if (env.IMAGE_TAG?.trim()){
        return env.IMAGE_TAG
    }
    def ecrImageTags = sh(script: "aws ecr describe-images --repository-name ${env.ECR_REPO_SHORT_NAME} --region ${env.ECR_REGION} --registry-id ${env.AWS_ID} --query 'sort_by(imageDetails,& imagePushedAt)[-1].imageTags[*]'", returnStdout: true)
    println "Hulk ${env.IMAGE_TAG} : ${ecrImageTags}"
    def lastImageTag =  Eval.me(ecrImageTags)
    // When no image is present for the repo, above AWS command provides a stringified null
    if (lastImageTag == null || lastImageTag.isEmpty() || lastImageTag == "null" ){
        //When no image exists ,  start with 1.0.0
        return "1.0.0"
    }
    Collections.sort(lastImageTag, Collections.reverseOrder());
    lastImageTag = lastImageTag[0]
    if (lastImageTag?.trim() == "" ||  lastImageTag?.trim() == "null" || lastImageTag == null ){
        //When no image exists ,  start with 1.0.0
        return "1.0.0"
