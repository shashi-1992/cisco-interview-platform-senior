                def jenkinsPipelineBranch = env.GIT_BRANCH?.replace('origin/', '')?.trim() ?: env.BRANCH_NAME
                pipelineMap.scmBranch = jenkinsPipelineBranch
                args.serviceBranch = pipelineMap.scmBranch
                echo "Set pipelineMap.scmBranch to Jenkins pipeline branch: ${pipelineMap.scmBranch} (CQA repo branch: ${cqaBranch})"
                args.lastCommitId = args.cqaCommitID
                
                // Debug: Show what was cloned
