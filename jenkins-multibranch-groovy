            echo "Successfully cloned exotel_configs from branch: ${args.exotelConfigBranch}"
            echo "Configs commit ID: ${args.configsCommitID}"
        }
    }

    if (args.exotelCodePaths != null && args.exotelCodePaths.size() > 0) {
        stage('Sparse checkout exotel_code') {
            // ExotelCodePaths array should be declared in the Jenkinsfile to run this block
