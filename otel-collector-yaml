# /Users/shashidhara.reddy/Implementation/otel/otel-ansible/roles/otel-collector/tasks/main.yml

---
- name: Include environment specific vars
  include_vars:
    file: "{{ env }}"

- name: Create otel user
  user:
    name: otel
    system: yes
    shell: /sbin/nologin
    create_home: no
  become: yes

- name: Create otel directories
  file:
    path: "{{ item }}"
    state: directory
    owner: "{{ otel_user | default('exotel') }}"
    group: "{{ otel_group | default('exotel') }}"
    mode: '0755'
  with_items:
    - "{{ otel_config_path }}"
    - "{{ otel_data_path }}"
    - /var/log/otel

- name: Download OTel Collector from S3
  s3:
    bucket: "{{ s3_build_bucket_name }}"
    object: "otel/{{ otel_package_name }}"
    dest: "/tmp/{{ otel_package_name }}"
    mode: get
    region: "{{ ansible_ec2_placement_region | default(aws_region) }}"
  become: yes
  when: otel_download_from_s3 | default(true)

- name: Download OTel Collector from URL
  get_url:
    url: "{{ otel_download_url }}"
    dest: "/tmp/{{ otel_package_name }}"
    mode: '0644'
  when: not (otel_download_from_s3 | default(true))

- name: Extract OTel Collector
  unarchive:
    src: "/tmp/{{ otel_package_name }}"
    dest: /usr/local/bin/
    remote_src: yes
    creates: /usr/local/bin/otelcol-contrib
  become: yes
  notify: restart otel-collector

- name: Set permissions on OTel binary
  file:
    path: /usr/local/bin/otelcol-contrib
    owner: root
    group: root
    mode: '0755'
  become: yes

- name: Deploy OTel Collector config
  template:
    src: otel-config.yaml.j2
    dest: "{{ otel_config_path }}/config.yaml"
    owner: "{{ otel_user | default('exotel') }}"
    group: "{{ otel_group | default('exotel') }}"
    mode: '0644'
    validate: '/usr/local/bin/otelcol-contrib validate --config=%s'
  notify: restart otel-collector
  ignore_errors: yes

- name: Deploy OTel Collector config (without validation)
  template:
    src: otel-config.yaml.j2
    dest: "{{ otel_config_path }}/config.yaml"
    owner: "{{ otel_user | default('exotel') }}"
    group: "{{ otel_group | default('exotel') }}"
    mode: '0644'
  notify: restart otel-collector

- name: Deploy systemd service file
  template:
    src: otel-collector.service.j2
    dest: /etc/systemd/system/otel-collector.service
    mode: '0644'
  become: yes
  notify: restart otel-collector

- name: Reload systemd daemon
  systemd:
    daemon_reload: yes
  become: yes

- name: Enable and start OTel Collector service
  systemd:
    name: otel-collector
    enabled: yes
    state: started
  become: yes

- name: Create logrotate config for OTel
  copy:
    dest: /etc/logrotate.d/otel-collector
    content: |
      /var/log/otel/*.log {
          daily
          rotate 7
          compress
          delaycompress
          missingok
          notifempty
          create 0644 {{ otel_user | default('exotel') }} {{ otel_group | default('exotel') }}
          postrotate
              systemctl reload otel-collector > /dev/null 2>&1 || true
          endscript
      }
    mode: '0644'
  become: yes

- name: Clean up downloaded package
  file:
    path: "/tmp/{{ otel_package_name }}"
    state: absent

---

# /Users/shashidhara.reddy/Implementation/otel/otel-ansible/roles/otel-collector/templates/otel-collector.service.j2

[Unit]
Description=OpenTelemetry Collector
Documentation=https://opentelemetry.io/docs/collector/
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ otel_user | default('exotel') }}
Group={{ otel_group | default('exotel') }}
ExecStart=/usr/local/bin/otelcol-contrib --config={{ otel_config_path }}/config.yaml
Restart=always
RestartSec=5
TimeoutStartSec=30
TimeoutStopSec=30

# Resource limits
LimitNOFILE=65536
LimitNPROC=4096
{% if otel_memory_limit is defined %}
MemoryLimit={{ otel_memory_limit }}
{% endif %}

# Security hardening
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true

# Environment variables
Environment="GOGC={{ otel_gogc | default(80) }}"
{% if otel_extra_env is defined %}
{% for env_var in otel_extra_env %}
Environment="{{ env_var.name }}={{ env_var.value }}"
{% endfor %}
{% endif %}

[Install]
WantedBy=multi-user.target

