---
- name: Deploy OpenTelemetry Collector
  hosts: all
  become: yes
  become_method: sudo
  user: exotel
  gather_facts: yes

  vars_files:
    - env-vars/{{ env }}

  vars:
    service: "otel-collector"

  pre_tasks:
    - name: Set default environment
      set_fact:
        env: "{{ env | default('qa') }}"

    - name: Set stamp/region
      set_fact:
        stamp: "{{ stamp | default('sg') }}"

    - name: Gather EC2 facts
      ec2_facts:
      when: ansible_ec2_instance_id is defined
      ignore_errors: yes

  roles:
    - otel-collector
    - configure-common-packages
    - { role: prometheus_node_exporter, tags: ["monitoring-setup"] }

  tasks: []
  post_tasks: []
```

