## 4. Commands — Citus maintenance & inspection

> Names may vary slightly by **Citus version**; use `\df citus*` in `psql` on the **coordinator**.

```sql
-- Extension
CREATE EXTENSION IF NOT EXISTS citus;

-- Cluster overview
SELECT * FROM citus_get_active_worker_nodes();
SELECT * FROM citus_tables WHERE citus_table_type = 'distributed';

-- Shard placement
SELECT * FROM citus_shards;
SELECT logicalrelid, shardid, shardlength, nodename, nodeport
FROM citus_shard_placement()
ORDER BY logicalrelid, shardid;

-- Move / rebalance (planned window; can be heavy)
SELECT citus_rebalance_start();
-- or monitor progress per docs: citus_rebalance_status(), etc.

-- Distributed deadlock / long transactions (coordinator)
SELECT * FROM citus_dist_stat_activity;  -- if available in your version

-- Connections per node (run on coordinator + workers as needed)
SELECT count(*), state FROM pg_stat_activity GROUP BY state;
SELECT pid, usename, application_name, client_addr, state, wait_event, query
FROM pg_stat_activity
WHERE state <> 'idle'
ORDER BY query_start;
```

```sql
-- Routine PostgreSQL (all nodes: coordinator + workers)
VACUUM (VERBOSE, ANALYZE) schema_name.table_name;
-- Autovacuum tuning: autovacuum_* settings per table if bloat

SELECT relname, n_live_tup, n_dead_tup, last_vacuum, last_autovacuum
FROM pg_stat_user_tables
WHERE schemaname NOT IN ('pg_catalog','information_schema')
ORDER BY n_dead_tup DESC
LIMIT 20;
```

