### Topic D — Huge file: regex match count without loading whole file

**Q:** Count lines matching a pattern in a multi-GB log.

**Code:**

```python
#!/usr/bin/env python3
"""stream_grep_count.py <path> <regex>"""
from __future__ import annotations

import re
import sys
from pathlib import Path


def count_matches(path: Path, pattern: re.Pattern[str]) -> int:
    n = 0
    with path.open(encoding="utf-8", errors="replace") as f:
        for line in f:
            if pattern.search(line):
                n += 1
    return n


def main() -> int:
    if len(sys.argv) != 3:
        print("usage: stream_grep_count.py <file> <regex>", file=sys.stderr)
        return 2
    path = Path(sys.argv[1])
    pat = re.compile(sys.argv[2])
    print(count_matches(path, pat))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
```

