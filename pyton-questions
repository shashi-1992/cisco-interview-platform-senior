## 4. REST API client — `urllib` (stdlib; no `requests` required)

```python
import json
import urllib.error
import urllib.request

def http_get_json(url: str, timeout: float = 10.0) -> dict:
    req = urllib.request.Request(url, headers={"Accept": "application/json"})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode())

def http_post_json(url: str, payload: dict, timeout: float = 10.0) -> dict:
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=data,
        method="POST",
        headers={"Content-Type": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode())

# if __name__ == "__main__":
#     print(http_get_json("https://httpbin.org/get"))
```

For **AWS-signed** APIs use `boto3.client("...")` instead.

