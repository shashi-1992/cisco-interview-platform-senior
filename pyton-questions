## Interview coding — small patterns (stdlib only)

### Palindrome

```python
def is_palindrome(s: str) -> bool:
    clean = "".join(c.lower() for c in s if c.isalnum())
    return clean == clean[::-1]
```

### Factorial

```python
def factorial(n: int) -> int:
    if n < 0:
        raise ValueError("n must be >= 0")
    out = 1
    for i in range(2, n + 1):
        out *= i
    return out
# or: import math; math.factorial(n)
```

### Prime number

```python
def is_prime(n: int) -> bool:
    if n < 2:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    for i in range(3, int(n**0.5) + 1, 2):
        if n % i == 0:
            return False
    return True
```

### Fibonacci series (first `n` terms)

```python
def fibonacci(n: int) -> list[int]:
    if n <= 0:
        return []
    if n == 1:
        return [0]
    out = [0, 1]
    while len(out) < n:
        out.append(out[-1] + out[-2])
    return out
```

### Even or odd

```python
def parity(n: int) -> str:
    return "even" if n % 2 == 0 else "odd"
```

### Remove duplicates (keep order)

```python
def unique(seq):
    return list(dict.fromkeys(seq))
```

### Merge dicts (later keys win)

```python
a = {"x": 1, "y": 2}
b = {"y": 99, "z": 3}
merged = {**a, **b}       # {'x': 1, 'y': 99, 'z': 3}
# Python 3.9+: merged = a | b
```

### Reverse string

```python
s = "hello"
rev = s[::-1]
```

### Anagram check (ignore case / extra spaces)

```python
from collections import Counter

def is_anagram(a: str, b: str) -> bool:
    def norm(s):
        return Counter(c.lower() for c in s if c.isalnum())
    return norm(a) == norm(b)
```

### Largest element

```python
def largest(nums: list[int]) -> int | None:
    if not nums:
        return None
    return max(nums)
```

### Regex problem — pull IPv4 addresses from text (logs / configs)

```python
import re

IPV4 = re.compile(
    r"\b(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}"
    r"(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\b"
)

line = "server 10.0.2.15 failed backup from 192.168.1.1"
print(IPV4.findall(line))   # ['10.0.2.15', '192.168.1.1']
```

**Why this pattern:** word boundaries `\b` avoid partial matches; octets use 0–255 ranges (interview-grade, not perfect for “invalid” combos like `999.999` if you pasted wrong—good enough for screening).

