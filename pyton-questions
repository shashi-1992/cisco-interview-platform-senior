### Example 2 — Log archival: rotate, gzip, stage for upload (cron-friendly)

**Real-time angle:** nightly job picks **closed** log files, compresses, moves to a staging dir for `aws s3 cp` / `gsutil` / internal NFS.

```python
#!/usr/bin/env python3
"""archive_logs.py — gzip *.log older than 1h into staging/, idempotent by skip-if-.gz-exists."""
from __future__ import annotations

import gzip
import shutil
import time
from pathlib import Path

SRC = Path("/var/log/myapp")
STAGING = Path("/var/log/myapp/staging")
MIN_AGE_SEC = 3600


def archive() -> None:
    STAGING.mkdir(parents=True, exist_ok=True)
    now = time.time()
    for logfile in SRC.glob("*.log"):
        if not logfile.is_file():
            continue
        if now - logfile.stat().st_mtime < MIN_AGE_SEC:
            continue
        out = STAGING / (logfile.name + ".gz")
        if out.exists():
            continue
        with logfile.open("rb") as fin, gzip.open(out, "wb", mtime=0) as fout:
            shutil.copyfileobj(fin, fout)
        logfile.unlink()
        print("archived", out)


if __name__ == "__main__":
    archive()
```

