## 2. CSV — read, filter, write

```python
import csv
from pathlib import Path

def filter_csv(src: Path, dst: Path, column: str, want: str):
    with src.open(newline="", encoding="utf-8") as fin:
        reader = csv.DictReader(fin)
        rows = [r for r in reader if r.get(column) == want]

    with dst.open("w", newline="", encoding="utf-8") as fout:
        if not rows:
            return
        writer = csv.DictWriter(fout, fieldnames=rows[0].keys())
        writer.writeheader()
        writer.writerows(rows)

if __name__ == "__main__":
    filter_csv(Path("input.csv"), Path("output.csv"), "env", "prod")
```

