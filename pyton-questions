### Topic A — Standard library: `os`, `sys`, `json`, `re`, `subprocess`

**Q:** CLI: load JSON config, find log files under a root, filter names with regex, run `sha256sum` (or `shasum`) on each match with timeout.

**Code (`stdlib` only; uses `shasum` on macOS, `sha256sum` on Linux if you swap `checksum_cmd`):**

```python
#!/usr/bin/env python3
"""scan_logs_checksum.py <config.json> — Topic A demo."""
from __future__ import annotations

import json
import re
import subprocess
import sys
from pathlib import Path


LOG_NAME = re.compile(r"^app-\d{4}-\d{2}-\d{2}\.log$")


def usage() -> None:
    print("usage: scan_logs_checksum.py <config.json>", file=sys.stderr)


def main() -> int:
    if len(sys.argv) != 2:
        usage()
        return 2
    cfg_path = Path(sys.argv[1])
    if not cfg_path.is_file():
        print(f"config not found: {cfg_path}", file=sys.stderr)
        return 2

    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        print(f"invalid JSON in {cfg_path}: {e}", file=sys.stderr)
        return 1

    root = Path(cfg["log_root"])
    # macOS: shasum -a 256 ; Linux: sha256sum
    checksum_cmd = cfg.get("checksum_cmd", ["shasum", "-a", "256"])
    timeout = int(cfg.get("checksum_timeout_sec", 30))

    matches: list[Path] = []
    for path in root.rglob("*.log"):
        if LOG_NAME.match(path.name):
            matches.append(path)

    for path in sorted(matches):
        try:
            proc = subprocess.run(
                [*checksum_cmd, str(path)],
                capture_output=True,
                text=True,
                timeout=timeout,
            )
        except subprocess.TimeoutExpired:
            print(f"TIMEOUT {path}", file=sys.stderr)
            continue
        if proc.returncode != 0:
            print(f"FAIL {path}: {proc.stderr.strip()}", file=sys.stderr)
            continue
        print(f"{path}: {proc.stdout.splitlines()[0] if proc.stdout else ''}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
```

Example `config.json`:

```json
{
  "log_root": "/var/log/myapp",
  "checksum_cmd": ["shasum", "-a", "256"],
  "checksum_timeout_sec": 15
}
```

