### Topic B — Reliability: logging, retries, bounded backoff (API + DB sketch)

**Q:** Batch job: HTTP GET then DB insert; handle **503** and transient DB errors with retries and structured logging.

**Code (stdlib + `urllib` to avoid mandatory `requests`; swap for `requests` in production):**

```python
#!/usr/bin/env python3
"""reliable_batch.py — Topic B demo: logging + exponential backoff + jitter."""
from __future__ import annotations

import json
import logging
import random
import time
import urllib.error
import urllib.request
from typing import Any, Callable

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s %(name)s %(message)s",
)
log = logging.getLogger("batch")


def fetch_json(url: str, timeout: float = 10.0) -> Any:
    req = urllib.request.Request(url, headers={"Accept": "application/json"})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode())


def is_retryable_http(err: BaseException) -> bool:
    if isinstance(err, urllib.error.HTTPError):
        return err.code in (408, 429, 502, 503, 504)
    return isinstance(err, (urllib.error.URLError, TimeoutError, OSError))


def with_retries(
    op: Callable[[], Any],
    *,
    max_attempts: int = 5,
    base_sec: float = 0.5,
    max_sec: float = 30.0,
    retryable: Callable[[BaseException], bool],
) -> Any:
    last: BaseException | None = None
    for attempt in range(1, max_attempts + 1):
        try:
            return op()
        except Exception as e:  # noqa: BLE001 — demo; narrow in prod
            last = e
            if not retryable(e) or attempt == max_attempts:
                log.exception("giving up attempt=%s err=%s", attempt, e)
                raise
            sleep = min(max_sec, base_sec * (2 ** (attempt - 1)))
            sleep *= 0.5 + random.random()  # jitter
            log.warning("retry attempt=%s sleep=%.2fs err=%s", attempt, sleep, e)
            time.sleep(sleep)
    assert last is not None
    raise last


def process_record(record_id: str, api_url: str) -> None:
    data = with_retries(lambda: fetch_json(f"{api_url}/records/{record_id}"), retryable=is_retryable_http)
    log.info("fetched record_id=%s keys=%s", record_id, list(data)[:5])

    def db_insert() -> None:
        # Replace with real DB; simulate deadlock with a custom error type in real code
        pass

    try:
        with_retries(db_insert, retryable=lambda e: "deadlock" in str(e).lower())
    except Exception:
        log.exception("db failed record_id=%s", record_id)
        raise


# if __name__ == "__main__":
#     process_record("123", "https://api.example.com")
```

