### Example 3 — Reliable push to backup: retries + `.done` marker (at-least-once safe)

**Real-time angle:** worker uploads `staging/*.gz`; only writes `file.gz.done` after HTTP 200; retries on 5xx with backoff; **never** deletes `.gz` until success.

```python
#!/usr/bin/env python3
"""reliable_upload.py — upload with backoff; touch .done only on success."""
from __future__ import annotations

import random
import time
import urllib.error
import urllib.request
from pathlib import Path

STAGING = Path("/var/log/myapp/staging")
UPLOAD_URL = "https://backup.example.com/ingest"  # placeholder


def upload_file(path: Path) -> None:
    done = path.with_name(path.name + ".done")
    if done.exists():
        return
    data = path.read_bytes()
    for attempt in range(1, 6):
        try:
            req = urllib.request.Request(
                UPLOAD_URL,
                data=data,
                method="PUT",
                headers={"Content-Type": "application/gzip"},
            )
            with urllib.request.urlopen(req, timeout=60) as resp:
                if 200 <= resp.status < 300:
                    done.write_text("ok\n")
                    return
        except urllib.error.HTTPError as e:
            if e.code >= 500 and attempt < 5:
                time.sleep(min(30, 0.5 * (2 ** (attempt - 1))) * (0.5 + random.random()))
                continue
            raise


def main() -> None:
    for gz in sorted(STAGING.glob("*.gz")):
        upload_file(gz)


if __name__ == "__main__":
    main()
```

