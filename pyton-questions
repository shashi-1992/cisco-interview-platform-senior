### Example 4 — Real-time webhooks: HTTP endpoint for delivery / CDR callbacks

**Real-time angle:** carriers or messaging partners POST delivery receipts; validate signature (HMAC), enqueue idempotently, return `200` fast.

```python
"""webhook_server.py — pip install flask"""
from __future__ import annotations

import hashlib
import hmac
import logging
from flask import Flask, request, abort

log = logging.getLogger("webhook")
app = Flask(__name__)
WEBHOOK_SECRET = b"change-me-in-vault"


@app.post("/webhooks/delivery")
def delivery():
    raw = request.get_data()
    sig = request.headers.get("X-Signature", "")
    expected = hmac.new(WEBHOOK_SECRET, raw, hashlib.sha256).hexdigest()
    if not hmac.compare_digest(sig, expected):
        abort(401)
    payload = request.get_json(force=True, silent=False)
    event_id = payload.get("event_id")
    log.info("delivery event_id=%s", event_id)
    # TODO: idempotent write to queue/DB by event_id
    return {"ok": True}, 200


if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO)
    app.run(host="127.0.0.1", port=8080)
```

