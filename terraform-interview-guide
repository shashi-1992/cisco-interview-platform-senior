## 6. Data sources

```hcl
data "aws_ami" "al2023" {
  most_recent = true
  owners      = ["amazon"]
  filter {
    name   = "name"
    values = ["al2023-ami-*-x86_64"]
  }
}

data "aws_vpc" "shared" {
  id = var.existing_vpc_id
}

resource "aws_instance" "x" {
  ami           = data.aws_ami.al2023.id
  subnet_id     = var.subnet_id
  instance_type = "t3.micro"
}
```

